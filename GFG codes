Arithmetic operation
#include <iostream>
using namespace std;

int main() {
    int x, y;
    cin >> x >> y;

    // code here
    int p = x + y;
    int q = x - y;
    int r = x * y;
    int s = x/y;
    int t = x%y;

    // The below code prints the output
    cout << p << " " << q << " " << r << " " << s << " " << t << endl;
    return 0;
}

Right angle triangle
#include <bits/stdc++.h>
using namespace std;

int main() {

    int n;
    cin >> n;

    // code here
    for(int i = 0;i < n;i++){
        for(int j = 0;j<=i;j++){
            cout << "*" << " ";
        }
        cout << endl;
    }

    return 0;
}

Descision making
#include <bits/stdc++.h>
using namespace std;

int main() {
    int n, m;
    cin >> n >> m;

    // code here
    if(n<m){
        cout << "less";
    }
    else if(n == m){
        cout << "equal";
    }
    else{
        cout << "greater";
    }

    return 0;
}

THE FIZZBUZZ PROBLEM
#include <bits/stdc++.h>
using namespace std;

int main() {
    int n;
    cin >> n;

    // code here
    if(n % 3 == 0 && n % 5 == 0){
        cout << "FizzBuzz";
    }
    else if(n % 5 == 0){
        cout << "Buzz";
    }
    else if(n % 3 == 0){
        cout << "Fizz";
    }
    else{
        cout << n;
    }

    return 0;
}
